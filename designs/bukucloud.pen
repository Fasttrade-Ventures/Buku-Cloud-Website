                        {
                          "type": "text",
                          "id": "DKgTn",
                          "name": "P",
                          "fill": "$ink",
                          "textGrowth": "fixed-width",
                          "width": "fill_container",
                          "content": "elcome to BukuCloud. This privacy policy explains how we collect, use, and protect your personal information when you use our accounting platform at app.bukucloud.com (the “Service”).",
                          "lineHeight": 1.7,
                          "fontFamily": "$font-body",
                          "fontSize": 16,
                          "fontWeight": "normal"
                        }
                      ]
                    },
                    {
                      "type": "text",
                      "id": "Og1z4",
                      "name": "P",
                      "fill": "$ink",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "This policy is structured in line with the Personal Data Protection Act 2010 (PDPA 2010). By using the Service, you consent to the practices described here.",
                      "lineHeight": 1.7,
                      "fontFamily": "$font-body",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "MWpih",

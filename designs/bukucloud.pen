                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "VRKgw",
                      "name": "H",
                      "fill": "$ink",
                      "content": "2. Information we collect",
                      "lineHeight": 1.2,
                      "fontFamily": "$font-display",
                      "fontSize": 28,
                      "fontWeight": "500",
                      "letterSpacing": -0.3
                    },
                    {
                      "type": "text",
                      "id": "KdK0j",
                      "name": "P",
                      "fill": "$ink",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We collect account information (name, email, phone number), company information (company name, SSM registration number, SST number), and accounting data you enter into the Service (invoices, bills, transactions).",
                      "lineHeight": 1.7,
                      "fontFamily": "$font-body",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "V4qzc",
                      "name": "P",
                      "fill": "$ink",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "When you interact with the Service, we collect activity logs including IP address, browser type, access time, and pages visited for security and analytics purposes.",
                      "lineHeight": 1.7,
                      "fontFamily": "$font-body",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "y7MJM",
                  "name": "Sec",

                  "gap": 16,
                  "children": [
                    {
                      "type": "text",
                      "id": "Hsk2G",
                      "name": "H",
                      "fill": "$ink",
                      "content": "3. How we use information",
                      "lineHeight": 1.2,
                      "fontFamily": "$font-display",
                      "fontSize": 28,
                      "fontWeight": "500",
                      "letterSpacing": -0.3
                    },
                    {
                      "type": "text",
                      "id": "dSQv8",
                      "name": "P",
                      "fill": "$ink",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "We use your information to: (a) provide and manage your account, (b) process subscription payments, (c) answer support enquiries, (d) send important notifications about the Service, and (e) comply with legal requirements such as MyInvois LHDN and PDPA 2010.",
                      "lineHeight": 1.7,
                      "fontFamily": "$font-body",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]

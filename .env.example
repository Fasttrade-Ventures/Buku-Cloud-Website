# Public marketing site URL — must match the live preferred host.
# Production redirects apex → www, so use www in all SEO signals.
# Production: https://www.bukucloud.com
NEXT_PUBLIC_SITE_URL=https://www.bukucloud.com

# BukuCloud SaaS app URL — used to build /register and /register/practice CTAs.
# Local dev:    NEXT_PUBLIC_APP_URL=http://127.0.0.1:8000
# Staging:      NEXT_PUBLIC_APP_URL=https://staging-app.bukucloud.com
# Production:   NEXT_PUBLIC_APP_URL=https://app.bukucloud.com
NEXT_PUBLIC_APP_URL=http://127.0.0.1:8000

# Search Console / Bing Webmaster Tools verification.
# Optional — leave empty until you've claimed the www property.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

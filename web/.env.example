# BukuCloud SaaS app URL — used to build /register and /register/practice CTAs.
# Local dev:    NEXT_PUBLIC_APP_URL=http://127.0.0.1:8000
# Staging:      NEXT_PUBLIC_APP_URL=https://staging-app.bukucloud.com
# Production:   NEXT_PUBLIC_APP_URL=https://app.bukucloud.com
NEXT_PUBLIC_APP_URL=http://127.0.0.1:8000

# Public marketing site URL — used as the canonical base for SEO metadata,
# sitemap.xml, robots.txt and Open Graph image URLs.
# Production: https://bukucloud.com
NEXT_PUBLIC_SITE_URL=https://bukucloud.com

# Search Console / Bing Webmaster Tools verification.
# Optional — leave empty until you've claimed the property.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
